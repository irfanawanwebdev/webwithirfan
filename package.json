{
  "name": "webwithirfan",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "WebWithIrfan — frontend developer & WordPress expert portfolio/agency site.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && vite build --ssr src/entry-server.tsx --outDir dist-server && node scripts/prerender.mjs",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc -b --noEmit",
    "gen-assets": "node scripts/gen-assets.mjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "gsap": "^3.12.5",
    "lenis": "^1.3.25",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "sharp": "^0.33.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
