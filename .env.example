# Contact form backend (Web3Forms — https://web3forms.com).
# 1. Go to web3forms.com, enter info@webwithirfan.com, and copy the access key
#    it emails you. Paste it below (and add the same in Vercel > Project >
#    Settings > Environment Variables).
# 2. Two recipients: in the Web3Forms dashboard for this key, set the recipient
#    to info@webwithirfan.com and add mirfanawan545@gmail.com as a CC / second
#    recipient. The mailto fallback already CCs both if the key is unset.
# The access key is public by design, so it is safe in the client bundle.
VITE_WEB3FORMS_KEY=

# Public site origin, used for canonical/OG URLs and sitemap.
VITE_SITE_URL=https://webwithirfan.com
