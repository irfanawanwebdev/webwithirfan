# Contact form backend.
# Create a free form at https://formspree.io and paste its endpoint here, e.g.
#   VITE_FORM_ENDPOINT=https://formspree.io/f/abcdwxyz
# If left unset, the form falls back to a mailto: link so it still works.
#
# Two recipients: submissions go to your Formspree account email
# (info@webwithirfan.com) and also copy mirfanawan545@gmail.com.
# The copy is sent via the form's hidden "_cc" field. If your Formspree plan
# ignores _cc, add the second address under the form's settings on formspree.io
# (Form > Settings > add email). The mailto fallback already CCs both.
VITE_FORM_ENDPOINT=

# Public site origin, used for canonical/OG URLs and sitemap.
VITE_SITE_URL=https://webwithirfan.com
